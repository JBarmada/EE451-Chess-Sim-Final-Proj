#!/usr/bin/env bash
#SBATCH --job-name=chess_omp_scaling
#SBATCH --exclusive
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=32
#SBATCH --time=01:00:00
#SBATCH --output=carc/logs/run_omp_scaling.%j.out
#SBATCH --error=carc/logs/run_omp_scaling.%j.err

# run_openmp_scaling.job — Thread-count scalability study at fixed 10M games.
# Runs sim10m_openmp at thread counts 1, 2, 4, 8, 16, 32.
# --exclusive ensures no co-located jobs contaminate thread measurements.
#
# Wall time budget (est.):
#   1t:~800s  2t:~425s  4t:~212s  8t:~110s  16t:~57s  32t:~43s  (~1647s total)
#   1hr limit gives ~2.2x safety buffer.
#
# Output per run: results/10m_openmp/{threads}/summary.txt (auto-namespaced)

set -euo pipefail

module purge
module load gcc

PROJ_DIR="${SLURM_SUBMIT_DIR}/.."
cd "${PROJ_DIR}"

BIN="./sim10m_openmp"
if [[ ! -x "${BIN}" ]]; then
    echo "ERROR: ${BIN} not found. Run build.sh first." >&2
    exit 1
fi

echo "============================================================"
echo "Chess OpenMP Thread-Scaling Study (10M games) — CARC Job"
echo "Job ID:    ${SLURM_JOB_ID}"
echo "Node:      $(hostname)"
echo "Started:   $(date -u +%Y-%m-%dT%H:%M:%SZ)"
echo "Directory: $(pwd)"
echo "Max CPUs allocated: ${SLURM_CPUS_PER_TASK}"
echo "============================================================"
echo ""

for threads in 1 2 4 8 16 32; do
    export OMP_NUM_THREADS=${threads}

    echo "--- [$(date -u +%H:%M:%S)] OMP_NUM_THREADS=${threads} ---"
    ${BIN}
    echo "--- [$(date -u +%H:%M:%S)] Done threads=${threads} ---"
    echo ""
done

echo "============================================================"
echo "OpenMP scaling study complete: $(date -u +%Y-%m-%dT%H:%M:%SZ)"
echo "Results written to: results/10m_openmp/{1,2,4,8,16,32}/summary.txt"
echo "============================================================"
