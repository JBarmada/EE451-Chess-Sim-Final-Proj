#!/usr/bin/env bash
#SBATCH --job-name=chess_omp_sizes
#SBATCH --exclusive
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=32
#SBATCH --time=00:30:00
#SBATCH --output=carc/logs/run_omp_sizes.%j.out
#SBATCH --error=carc/logs/run_omp_sizes.%j.err

# run_openmp_sizes.job — Problem-size throughput study at 32 threads.
# Runs all four sizes (100k, 1m, 10m, 100m) with OMP_NUM_THREADS=32.
# Paired with run_serial.job results to compute speedup per problem size.
# --exclusive ensures all 32 cores are uncontested.
#
# Wall time budget at 32 threads (est.):
#   100k:~0.6s  1m:~4s  10m:~43s  100m:~430s  (~478s total)
#   30min limit gives ~3.7x safety buffer.
#
# Output: results/{size}_openmp/32/summary.txt

set -euo pipefail

module purge
module load gcc

PROJ_DIR="${SLURM_SUBMIT_DIR}/.."
cd "${PROJ_DIR}"

export OMP_NUM_THREADS=32

echo "============================================================"
echo "Chess OpenMP Problem-Size Study (32 threads) — CARC Job"
echo "Job ID:    ${SLURM_JOB_ID}"
echo "Node:      $(hostname)"
echo "Started:   $(date -u +%Y-%m-%dT%H:%M:%SZ)"
echo "Directory: $(pwd)"
echo "OMP_NUM_THREADS: ${OMP_NUM_THREADS}"
echo "============================================================"
echo ""

for size in 100k 1m 10m 100m; do
    BIN="./sim${size}_openmp"
    if [[ ! -x "${BIN}" ]]; then
        echo "ERROR: ${BIN} not found. Run build.sh first." >&2
        exit 1
    fi

    echo "--- [$(date -u +%H:%M:%S)] Starting sim${size}_openmp (32 threads) ---"
    ${BIN}
    echo "--- [$(date -u +%H:%M:%S)] Finished sim${size}_openmp ---"
    echo ""
done

echo "============================================================"
echo "OpenMP sizes study complete: $(date -u +%Y-%m-%dT%H:%M:%SZ)"
echo "Results written to: results/{100k,1m,10m,100m}_openmp/32/summary.txt"
echo "============================================================"
