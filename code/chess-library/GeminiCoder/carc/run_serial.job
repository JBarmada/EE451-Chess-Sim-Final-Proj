#!/usr/bin/env bash
#SBATCH --job-name=chess_serial
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=1
#SBATCH --time=04:00:00
#SBATCH --output=carc/logs/run_serial.%j.out
#SBATCH --error=carc/logs/run_serial.%j.err

# run_serial.job — Run all serial chess simulations (baseline for speedup).
# Submit from GeminiCoder/: sbatch carc/run_serial.job
# Or let submit_all.sh handle it.
#
# Wall time budget:
#   100k: ~8s  |  1m: ~80s  |  10m: ~800s  |  100m: ~8000s  (~2.2 hrs total)
#   4hr limit gives ~1.8x safety buffer.

set -euo pipefail

module purge
module load gcc

# SLURM_SUBMIT_DIR is the directory sbatch was called from.
# We submit from carc/, so GeminiCoder/ is one level up.
PROJ_DIR="${SLURM_SUBMIT_DIR}/.."
cd "${PROJ_DIR}"

# Prevent accidental OpenMP threading in the serial binary
export OMP_NUM_THREADS=1

echo "============================================================"
echo "Chess Serial Simulation — CARC Job"
echo "Job ID:    ${SLURM_JOB_ID}"
echo "Node:      $(hostname)"
echo "Started:   $(date -u +%Y-%m-%dT%H:%M:%SZ)"
echo "Directory: $(pwd)"
echo "============================================================"
echo ""

for size in 100k 1m 10m 100m; do
    BIN="./sim${size}_serial"
    if [[ ! -x "${BIN}" ]]; then
        echo "ERROR: ${BIN} not found. Run build.sh first." >&2
        exit 1
    fi

    echo "--- [$(date -u +%H:%M:%S)] Starting sim${size}_serial ---"
    ${BIN}
    echo "--- [$(date -u +%H:%M:%S)] Finished sim${size}_serial ---"
    echo ""
done

echo "============================================================"
echo "All serial runs complete: $(date -u +%Y-%m-%dT%H:%M:%SZ)"
echo "Results written to: results/{100k,1m,10m,100m}_serial/summary.txt"
echo "============================================================"
